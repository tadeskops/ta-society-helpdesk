# Pin the public npm registry for this project. This is a personal
# `tadeskops` repo running on free public infrastructure; a corporate
# user-global ~/.npmrc must not redirect installs here.
# See .github/copilot-instructions.md §0 item 7.
registry=https://registry.npmjs.org/

# Clear any auth that might have been inherited from ~/.npmrc.
//registry.npmjs.org/:_authToken=
always-auth=false

# Local dev hygiene.
fund=false
audit=false
